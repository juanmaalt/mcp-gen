{
  "name": "mcp-gen",
  "version": "0.1.0",
  "description": "Generate MCP tool definitions from your code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-gen": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
